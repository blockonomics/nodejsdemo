# Blockonomics API key — Dashboard → Stores
BLOCKONOMICS_API_KEY=your_api_key

# Widget UID of the parent product — Dashboard → Buttons & Links → Products
PARENT_PRODUCT_UID=your_parent_product_uid

# Shared secret appended to the Order Hook URL. Must match the value you put in
# Dashboard → Buttons & Links → Options.
ORDER_CALLBACK_SECRET=any_random_long_string

PORT=3000
PUBLIC_URL=http://localhost:3000
