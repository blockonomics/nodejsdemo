# Copy this to .env and fill in the blanks.

# Your Blockonomics API key (Merchants -> Settings -> API).
BLOCKONOMICS_API_KEY=your_api_key_here

# Where this app is reachable from the public internet. In dev, run something
# like `ngrok http 3000` and paste the https URL here so Blockonomics can reach
# your webhook.
PUBLIC_URL=https://your-tunnel.ngrok.app

# A secret you invent. It's appended to your callback URL and checked on every
# webhook so randoms can't mark orders paid.
CALLBACK_SECRET=change_me_to_something_random

# Your USDT (ERC-20) receive address. Every USDT order is paid into this one
# address -- see the reconciliation notes in the README.
USDT_RECEIVE_ADDRESS=0xYourUsdtReceiveAddress

# 0 = Ethereum mainnet, 1 = Sepolia testnet. Keep this the same everywhere.
TESTNET=0

# USDT ERC-20 contract for the EIP-681 fallback QR. Leave blank on mainnet to use
# Tether's well-known contract. On testnet the docs don't publish a fixed USDT
# contract, so set the one you're testing against (or leave blank — the Web3
# component builds the tx itself and is the intended path on testnet).
USDT_CONTRACT=

PORT=3000
