# Copy this to .env and fill in the blanks.

# Your Blockonomics API key (Merchants -> Settings -> API).
BLOCKONOMICS_API_KEY=your_api_key_here

# Where this app is reachable from the public internet. In dev, run
# `ngrok http 3000` and paste the https URL here so Blockonomics can reach your
# webhook. On the free ngrok tier this changes every restart — update it (and the
# dashboard callback URL) each time.
PUBLIC_URL=https://your-tunnel.ngrok-free.app

# A secret you invent. It's appended to your callback URL and checked on every
# webhook so randoms can't mark orders paid. Make it long and random.
CALLBACK_SECRET=change_me_to_something_random

PORT=3000
